# Server
PORT=3000
NODE_ENV=development

# JWT Secrets (use strong, random strings in production)
ACCESS_TOKEN_SECRET=your-super-secret-access-token-key-change-this
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-this
RESET_TOKEN_SECRET=your-super-secret-reset-token-key-change-this

# Token Lifetimes
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
RESET_TOKEN_EXPIRY=15m

# Database (placeholder for future implementation)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=auth_system
DB_USER=postgres
DB_PASSWORD=postgres
